import "std/io";
import "std/random";

fun checkPermutation(values: []Int, expectedSize: Int) Int {
    var seen: [256]Bool;
    var i: Int = 0;

    while i < expectedSize {
        var v: Int = values[i];
        if v < 1 || v > expectedSize {
            return 1;
        }
        if seen[v] {
            return 2;
        }
        seen[v] = true;
        i = i + 1;
    }

    i = 1;
    while i <= expectedSize {
        if !seen[i] {
            return 3;
        }
        i = i + 1;
    }

    return 0;
}

fun main() Int {
    var rng: random.Rng = new random.Rng(42, 54);

    // Stress bounded generation for common bounds used by std/random APIs.
    var i: Int = 0;
    while i < 200000 {
        var a: UInt = rng.nextUIntBounded(1);
        if a >= 1 {
            return 10;
        }

        var b: UInt = rng.nextUIntBounded(2);
        if b >= 2 {
            return 11;
        }

        var c: UInt = rng.nextUIntBounded(6);
        if c >= 6 {
            return 12;
        }

        var d: UInt = rng.nextUIntBounded(100);
        if d >= 100 {
            return 13;
        }

        i = i + 1;
    }

    // Stress range APIs for bound correctness.
    i = 0;
    while i < 200000 {
        var x: Int = rng.nextRange(10, 20);
        if x < 10 || x >= 20 {
            return 20;
        }

        var y: Int = rng.nextRangeInclusive(1, 6);
        if y < 1 || y > 6 {
            return 21;
        }

        i = i + 1;
    }

    // Stress shuffle permutation validity.
    i = 0;
    while i < 2000 {
        var values: [8]Int = {1, 2, 3, 4, 5, 6, 7, 8};
        rng.shuffleInt(values);

        var ok: Int = checkPermutation(values, 8);
        if ok != 0 {
            return 30 + ok;
        }

        i = i + 1;
    }

    io.println("tmp_random_stress: OK");
    return 0;
}
