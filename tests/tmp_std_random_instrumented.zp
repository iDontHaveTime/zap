import "std/io";
import "std/random";
import "std/convert";
import "std/string";

const BIG_U64: UInt64 = 15726070495360670683;
const PCG_MULT: UInt64 = 6364136223846793005;

fun printArray(values: []Int) {
    var i: Int = 0;
    while i < values.len {
        io.printInt(values[i]);
        if i + 1 < values.len {
            io.printf(",");
        }
        i = i + 1;
    }
    io.printf("\n");
}

fun verifyPermutation(values: []Int, n: Int) Int {
    var seen: [9]Bool = {false, false, false, false, false, false, false, false, false};

    var i: Int = 0;
    while i < n {
        var value: Int = values[i];
        if value < 1 || value > n {
            io.println("verifyPermutation: out of range");
            io.printInt(value);
            io.printf("\n");
            return 1;
        }
        if seen[value] {
            io.println("verifyPermutation: duplicate detected");
            io.printInt(value);
            io.printf("\n");
            return 2;
        }
        seen[value] = true;
        i = i + 1;
    }

    i = 1;
    while i <= n {
        if !seen[i] {
            io.println("verifyPermutation: missing value");
            io.printInt(i);
            io.printf("\n");
            return 3;
        }
        i = i + 1;
    }

    return 0;
}

fun main() Int {
    io.println("tmp_std_random_instrumented: begin");

    var big: UInt64 = BIG_U64;
    if big != 15726070495360670683 {
        io.println("BIG_U64 regression failed");
        return 1;
    }

    var mult: UInt64 = PCG_MULT;
    if mult != 6364136223846793005 {
        io.println("PCG_MULT regression failed");
        return 2;
    }

    var rng: random.Rng = new random.Rng(42, 54);

    var first: UInt = rng.nextUInt32();
    var second: UInt = rng.nextUInt32();

    var again: random.Rng = new random.Rng(42, 54);
    if first != again.nextUInt32() {
        io.println("determinism check #1 failed");
        return 3;
    }
    if second != again.nextUInt32() {
        io.println("determinism check #2 failed");
        return 4;
    }

    var pcg: random.Pcg32 = new random.Pcg32(42, 54);
    var rnd: random.Random = new random.Random(42, 54);
    if pcg.nextUInt32() != rnd.nextUInt32() {
        io.println("alias consistency failed");
        return 5;
    }

    io.println("range pre-check loop begin");
    var i: Int = 0;
    while i < 64 {
        var x: Int = rng.nextRange(10, 20);
        if x < 10 || x >= 20 {
            io.println("nextRange out of bounds");
            io.printInt(i);
            io.printf("\n");
            return 6;
        }

        var y: Int = rng.nextRangeInclusive(1, 6);
        if y < 1 || y > 6 {
            io.println("nextRangeInclusive out of bounds");
            io.printInt(i);
            io.printf("\n");
            return 7;
        }

        var u: UInt = rng.nextUIntBounded(100);
        if u >= 100 {
            io.println("nextUIntBounded out of bounds");
            io.printInt(i);
            io.printf("\n");
            return 8;
        }

        i = i + 1;
    }
    io.println("range pre-check loop done");

    if rng.chance(0.0) {
        io.println("chance(0.0) failed");
        return 9;
    }
    if !rng.chance(1.0) {
        io.println("chance(1.0) failed");
        return 10;
    }

    var f: Float64 = rng.nextFloat64();
    if f < 0.0 || f >= 1.0 {
        io.println("nextFloat64 out of bounds");
        return 11;
    }

    var helper: Int = random.randomRange(rng, 100, 110);
    if helper < 100 || helper >= 110 {
        io.println("randomRange helper out of bounds");
        return 12;
    }

    var values: [8]Int = {1, 2, 3, 4, 5, 6, 7, 8};
    io.println("before shuffle:");
    printArray(values);

    rng.shuffleInt(values);

    io.println("after shuffle:");
    printArray(values);

    var permRc: Int = verifyPermutation(values, 8);
    if permRc != 0 {
        io.println("permutation verification failed");
        io.printInt(permRc);
        io.printf("\n");
        return 20;
    }

    var changed: Bool = false;
    i = 0;
    while i < 8 {
        if values[i] != i + 1 {
            changed = true;
        }
        i = i + 1;
    }
    if !changed {
        io.println("shuffle did not change sequence");
        return 21;
    }

    if string.eq(convert.toString(helper), "") {
        io.println("helper toString empty guard failed");
        return 18;
    }

    io.println("tmp_std_random_instrumented: success");
    return 0;
}
