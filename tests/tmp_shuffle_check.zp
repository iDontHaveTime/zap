import "std/io";
import "std/random";

fun main() Int {
    io.println("shuffle check: start");

    var rng: random.Rng = new random.Rng(42, 54);
    var values: [8]Int = {1, 2, 3, 4, 5, 6, 7, 8};

    io.println("before:");
    var i: Int = 0;
    while i < 8 {
        io.printInt(values[i]);
        i = i + 1;
    }

    io.println("shuffle:");
    rng.shuffleInt(values);

    io.println("after:");
    i = 0;
    while i < 8 {
        io.printInt(values[i]);
        i = i + 1;
    }

    io.println("validate:");
    var seen: [9]Bool = {false, false, false, false, false, false, false, false, false};

    i = 0;
    while i < 8 {
        var value: Int = values[i];
        io.printInt(value);

        if value < 1 || value > 8 {
            return 1;
        }

        if seen[value] {
            return 2;
        }

        seen[value] = true;
        i = i + 1;
    }

    io.println("done");
    return 0;
}
